# Example: copy to .env and edit

# OAuth / API
PORT=3456
API_KEY=
ATOMCODE_PLATFORM_SERVER=https://acs.atomgit.com
ATOMCODE_CODINGPLAN_API_BASE=https://api.gitcode.com/api/v5

# Dashboard access (leave empty = open access)
DASHBOARD_PASSWORD=

# Logging
LOG_LEVEL=info

# Auto-claim
AUTO_CLAIM_PRO=false

# Monitoring
MONITOR_INTERVAL=300000
MONITOR_WEBHOOK=
MONITOR_WARN_PERCENT=80
